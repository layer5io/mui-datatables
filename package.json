    "diff": "^8.0.4",
    "minimatch": ">=3.1.4",
    "serialize-javascript": "^7.0.4"
  },
  "sideEffects": false,
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "test"
  }
