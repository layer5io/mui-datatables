    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "clsx": "^2.1.1",
    "lodash.assignwith": "^4.2.0",
    "lodash.clonedeep": "^4.5.0",
    "lodash.debounce": "^4.0.8",
    "lodash.find": "^4.6.0",
    "lodash.isundefined": "^3.0.1",
